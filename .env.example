# Django settings and docker-compose.yml are configured with sensible defaults
# for development so everything works out of the box with `docker compose up`.
# You only need to set variables here if you want to change the configuration.
#
# Copy this file to .env and uncomment the lines you want to change.

####################
#  Docker Compose
####################

# Set the project name. The default is the directory name, which is used as a
# prefix in log output and container names.
#export COMPOSE_PROJECT_NAME=lighthouse

# Expose service ports on the host so you can connect with local GUI tools
# (e.g. pgAdmin, Redis Insight). Only needed if the defaults conflict with
# other locally running services.
#export DOCKER_DJANGO_PORT_FORWARD=127.0.0.1:8000
#export DOCKER_POSTGRES_PORT_FORWARD=127.0.0.1:5432
#export DOCKER_REDIS_PORT_FORWARD=127.0.0.1:6379

# Restart policy applied to all services. Set to 'unless-stopped' in production.
#export DOCKER_RESTART_POLICY=no

# Health check command for the django service. In production, protect the
# endpoint with token authentication by setting DJANGO_WATCHMAN_TOKENS.
# The token is passed as a URL parameter: /watchman/ping?watchman-token=<token>
# In development you can set this to /bin/true to suppress health check logs.
#export DOCKER_DJANGO_HEALTHCHECK_TEST=curl localhost:8000/watchman/ping

####################
#  Postgres Image
####################

#export POSTGRES_USER=postgres
#export POSTGRES_PASSWORD=postgres
#export POSTGRES_DB=postgres

####################
#  Connection URLs
####################

# These default to localhost for native installs. docker-compose.yml overrides
# them automatically with the correct container hostnames when using Docker.
#export BROKER_URL=redis://localhost:6379/1
#export CACHE_URL=redis://localhost:6379/0
#export DATABASE_URL=postgres://postgres:password@localhost:5432/postgres

