#!/usr/bin/env python3
"""
Replace the 'Latest' section heading in CHANGELOG.rst with the given version
number, and prepend a fresh empty 'Latest' section for future unreleased notes.

Usage:
    update-changelog <new-version>

Example:
    update-changelog v0.2.0

Before:
    Latest
    ------
    - Added desktop emulation support.

After:
    Latest
    ------


    v0.2.0
    ------
    - Added desktop emulation support.
"""

import re
import sys
from pathlib import Path

if len(sys.argv) != 2:
    print(f"Usage: {sys.argv[0]} <new-version>", file=sys.stderr)
    sys.exit(1)

new_version = sys.argv[1]
path = Path("CHANGELOG.rst")

if not path.exists():
    print(f"Error: {path} not found", file=sys.stderr)
    sys.exit(1)

text = path.read_text()

# Replace the "Latest\n------" heading with a new "Latest" section (for
# future unreleased notes) followed by the versioned heading.  The version
# heading underline must be at least as long as the title (RST requirement).
underline = "-" * len(new_version)
updated, count = re.subn(
    r"^Latest\n-+",
    f"Latest\n------\n\n\n{new_version}\n{underline}",
    text,
    count=1,
    flags=re.MULTILINE,
)

if count == 0:
    print(
        f"Warning: no 'Latest' section found in {path} — changelog not updated.",
        file=sys.stderr,
    )
    sys.exit(0)

path.write_text(updated)
print(f"Updated {path}: 'Latest' → {new_version}")
